  "event": {
    "top_event": "Fire from unattended cutting torch",
    "incident_type": "Fire",
    "costs": null,
    "actions_taken": [
      "Worker extinguished flame using portable fire extinguisher",
      "Control room activated general alarm",
      "Full muster and assembly of Incident Command System team",
      "Fire Team dispatched to scene",
      "Fire watch designated and posted in Safe Welding Area",
      "All personnel returned to duties after all clear"
    ],
    "summary": "On 20 August 2022 at 1007 hours, a worker discovered a small flame emanating from an unattended oxygen/acetylene cutting torch hanging from a bulkhead in a Safe Welding Area on the Ursa TLP. The worker immediately extinguished the flame using a nearby portable fire extinguisher and notified the Control Room. A general alarm was sounded, full muster conducted, and Fire Team dispatched. No flame, smoke, or damage was observed by the Fire Team. The incident was caused by construction personnel failing to close torch bottle valves, depressurize lines, and fully tighten the torch head valve after switching to a plasma cutter. Sparks from the plasma cutter subsequently ignited acetylene gas leaking from the improperly secured torch. No injuries or pollution resulted.",
    "recommendations": [
      "Close torch bottle valves when not in use",
      "Depressurize torch lines after bottle valves are closed",
      "Check equipment before work to ensure connections are tight",
      "Personnel utilizing Safe Welding Area should be mindful of spark direction and what is in the area"
    ],
    "key_phrases": [
      "unattended oxygen/acetylene cutting torch",
      "Safe Welding Area",
      "torch bottle valves not closed",
      "torch lines not depressurized",
      "acetylene valve not fully closed tight",
      "sparks from plasma cutter",
      "human performance error",
      "inattention to task",
      "not aware of hazards"
    ]
  },
