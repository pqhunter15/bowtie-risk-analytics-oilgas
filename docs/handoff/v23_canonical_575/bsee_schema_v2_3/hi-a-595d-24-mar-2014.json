  "event": {
    "top_event": "Worker struck by falling drill line cable",
    "incident_type": "Struck by object / Lifting device failure",
    "costs": null,
    "actions_taken": [
      "Injured person placed on litter and lowered to main deck",
      "Treated by rig medic",
      "Transported to Lake Charles, LA at 18:20"
    ],
    "summary": "On 24-MAR-2014 at 1630 hours, during stringing down block operations on Platform D (Blake 1505 rig), a 1 3/8 inch drill line cable failed to remain in the snake grip and fell, striking a worker manning the hydraulic drill line spool winch control on the left shoulder and right hip. The drill line cable was not properly degreased before insertion into the snake grip, and improper clamping using manila rope and duct tape instead of manufacturer-specified methods contributed to the failure. An 'all stop' was called but insufficient time remained to prevent the incident.",
    "recommendations": [
      "Lessee will assure that manufacturer's specifications and instructions for use of a snake grip are followed completely during stringing down block operations"
    ],
