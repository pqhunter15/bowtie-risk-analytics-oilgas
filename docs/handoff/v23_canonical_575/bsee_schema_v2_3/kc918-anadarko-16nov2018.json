  "event": {
    "top_event": "Facial injury from pressurized hydraulic line strike",
    "incident_type": "Other Injury",
    "costs": null,
    "actions_taken": [
      "Injured hydraulic mechanic reported to Rig Medic at 1540 hours",
      "Medivac helicopter evacuation to West Jefferson Medical Center in Marrero, Louisiana",
      "Medical treatment including sutures to lacerations to mouth and chin"
    ],
    "summary": "On 16 November 2018 at 1530 hours, a Diamond Offshore hydraulic mechanic sustained a facial injury while changing out a Hilman roller on the blowout preventer carrier frame aboard the Diamond Ocean Blackhawk drillship. During the operation, a 30-ton Enerpac hydraulic jack fell due to miscommunication between the hydraulic mechanic and rig mechanic operating the hydraulic pump. The falling jack sheared the hydraulic line fitting on an adjacent 25-ton Enerpac hydraulic jack, causing the pressurized hydraulic line to strike the mechanic's face. The mechanic was evacuated by helicopter and received medical treatment for facial lacerations.",
    "recommendations": [
      "Install a rigid support system when lifting heavy equipment"
    ],
    "key_phrases": [
      "miscommunication",
      "hydraulic jack failure",
      "unsecured equipment",
      "inadequate supervision",
      "improper body placement",
      "corrosion-related equipment failure"
    ]
  },
