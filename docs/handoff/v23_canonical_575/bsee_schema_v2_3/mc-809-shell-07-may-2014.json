  "event": {
    "top_event": "Hand caught between sheave and belt during pump maintenance",
    "incident_type": "Slip/Trip/Fall - Hand Injury",
    "costs": null,
    "actions_taken": [
      "Injured person treated by URSA Medic",
      "Medevaced to West Jefferson Hospital",
      "Intravenous line started and Morphine administered",
      "Offshore Installation Manager notified",
      "Doctor consulted via Telemed unit"
    ],
    "summary": "On May 7, 2014 at 19:30, an AGI Mechanic contractor working on a Crosby Methanol Pump (PZZ-802) on the Shell Ursa TLP had his left hand caught between the sheave and belt while adjusting the motor with a ratchet and checking belt tension manually instead of using a tension tester. The mechanic yanked his hand out, causing lacerations to his left index, middle, and ring fingers. He was treated on-site and medevaced for further medical care.",
    "recommendations": [],
