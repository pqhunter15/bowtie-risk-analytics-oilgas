  "event": {
    "top_event": "Injured Person's arm pinned between swinging Torpedo Guide door and frame",
    "incident_type": "Lost Time Accident (>3 days)",
    "costs": null,
    "actions_taken": [
      "Create task-specific JSA for TG removal",
      "Evaluate feasibility of mechanical devices for maneuvering suspended torpedo guide",
      "Paint/stencil NO-GO Zones to highlight line of fire hazard and pinch/crush points",
      "Modify TG door to secure in open position to prevent movement"
    ],
    "summary": "On September 10, 2022, at approximately 1600 hours, a floor-hand aboard the Helix Q-4000 suffered a fractured right arm when the unsecured Torpedo Guide (TG) door swung open and pinned his arm against the TG frame while he was manually pushing on the TG frame during removal operations. The incident resulted in lost time greater than 3 days and evacuation to shore.",
    "recommendations": [
      "Ensure personnel follow JSA procedures and/or apply engineering controls to mitigate identified hazards",
      "Develop written procedures specific to TG removal rather than assuming removal is reverse of installation",
      "Implement mechanical devices or rigging configurations to control load movement without manual hand contact",
      "Engineer TG door to prevent uncontrolled swinging"
    ],
    "key_phrases": [
      "swinging door hazard",
      "manual hand control failure",
      "inadequate written procedures",
      "unsecured lifting equipment",
      "pinch point injury",
      "JSA inadequacy"
    ]
  },
