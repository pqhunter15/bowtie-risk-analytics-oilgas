  "event": {
    "top_event": "Struck by falling vee-door gate",
    "incident_type": "Struck-by injury requiring evacuation",
    "costs": null,
    "actions_taken": [
      "Injured person evacuated for medical evaluation",
      "On-site investigation conducted by BSEE inspectors on 26-Feb-2015",
      "Review of Job Safety Analysis and Ensco Work Instructions"
    ],
    "summary": "On 21-Feb-2015 at 0400 hours, while permanently abandoning well A1 on the EC-346A platform, an unsecured vee-door gate (120 lbs) that had been removed and leaned against a storage container fell and struck a worker on the right knee. The worker fell and was unable to walk under his own power. He was evacuated and diagnosed with an Avulsion Fracture of the knee, requiring restrictive work for more than three days. The gate removal was not covered in the Job Safety Analysis or Work Instructions, and Ensco had no procedures for removing or storing the gate.",
    "recommendations": [
      "Lake Charles District office has no recommendations"
    ],
