  "event": {
    "top_event": "Finger Amputation from Mud Bucket Handling",
    "incident_type": "Crush Injury / Amputation",
    "costs": null,
    "actions_taken": [
      "Injured person reported to medic",
      "Rig Manager and Company Man contacted",
      "Injured person transported to shore on 26-June-2018",
      "Onshore surgeon attempted to save fingertip with sutures",
      "Distal phalanx amputation performed on 27-June-2018"
    ],
    "summary": "On 26-June-2018 at 15:15 hours, while moving a mud bucket into storage on the rig floor using an air hoist, an injured floorhand's right ring finger was caught and crushed between the mud bucket handle and a snubbing post when the air hoist operator unexpectedly set the bucket down. The crew failed to designate a flagger/signaler and did not follow hands-free procedures or hoisting guidelines. The finger was severely lacerated and subsequently amputated at the distal phalanx.",
    "recommendations": [],
