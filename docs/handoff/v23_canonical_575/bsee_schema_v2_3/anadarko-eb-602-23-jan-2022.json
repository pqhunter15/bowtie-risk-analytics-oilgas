  "event": {
    "top_event": "Fall from Height",
    "incident_type": "Slip/Trip/Fall",
    "costs": null,
    "actions_taken": [
      "BSEE onsite investigation performed on 27 January 2022",
      "Site survey of incident location conducted",
      "Job Safety and Environmental Analysis (JSEA) reviewed",
      "Training certificates and documents gathered",
      "Witness interviews conducted",
      "Photographs taken",
      "Personal protective equipment inspected",
      "Emergency rescue plan activated and executed"
    ],
    "summary": "On 23 January 2022 at approximately 1545 hours, a Blake International floorhand on the Nansen SPAR platform was instructed to ascend the derrick to check a light plug connection. After completing the task, the injured party (IP) began ascending to retrieve a Self Retracting Line (SRL) at the top of the derrick. The Driller ordered the IP to descend immediately. Upon reaching the derrick access platform approximately 11 feet above the A-frame walkway, the IP disconnected both fall protection lanyards, removing his 100 percent tie-off. The IP then lost his balance, fell off the access platform, struck his head on the A-frame walkway edge, and sustained moderate internal injuries and head lacerations requiring multiple back surgeries and sutures.",
    "recommendations": [
      "Ensure SRL is readily accessible with tag line to prevent use of loop-back lanyards",
      "Install alternative ladder safety systems or safety cages to reduce fatigue",
      "Reinforce documented safety procedures compliance (100% tie-off requirement)",
      "Ensure emergency rescue plans are explicitly discussed and marked on JSEA prior to work"
    ],
    "key_phrases": [
      "100% tie-off requirement",
      "derrick access platform",
      "fall protection",
      "Self Retracting Line (SRL)",
      "loop-back lanyard",
      "loss of balance",
      "dizziness",
      "emergency rescue plan"
    ]
  },
