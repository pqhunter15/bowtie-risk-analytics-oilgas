    "top_event": "Finger Fracture During Crane Lifting Operations",
    "incident_type": "Slip/Trip/Fall - Hand Injury",
    "costs": null,
    "actions_taken": [
      "Contract employee transported to medical facility for treatment",
      "BSEE Lafayette District conducted onsite investigation on October 10, 2018"
    ],
    "summary": "On October 6, 2018 at approximately 0930 hours, a contract employee injured his index finger on his left hand while attempting to position a cutting box on the deck during lifting operations. The cutting box was being lowered by the platform crane when the sling caught the lid and lifted it several inches. As the crane operator lowered the cutting box, the employee placed his hands between the lid and the box to control it. When tension was released from the sling, the lid dropped and smashed the employee's left index finger, resulting in a fracture.",
    "recommendations": [
      "Utilize taglines to help control the load during lifting operations to prevent employees from placing hands in hazardous locations"
    ],
    "key_phrases": [
      "cutting box",
      "crane lifting operations",
      "sling caught lid",
      "hand placement in hazardous location",
      "tagline not utilized",
      "fractured finger"
    ]
  },
