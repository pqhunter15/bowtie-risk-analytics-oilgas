  "event": {
    "top_event": "Chemical exposure to personnel",
    "incident_type": "Lost Time Accident (LTA > 3 days)",
    "costs": null,
    "actions_taken": [
      "Injured person escorted to eyewash station 21 ft away",
      "First aid treatment administered by offshore medic",
      "Helicopter evacuation on 18 April 2021",
      "Stainless steel fixed mechanical barrier installed to prevent chemical spray",
      "Hazardous chemical awareness program planned"
    ],
    "summary": "On 17 April 2021 at 1415 hours, a stack operator was contacted with asphaltene inhibitor on the arms and face while attempting to open chemical injection valves to Well AC-006 on the Appomattox platform. The incident was caused by a loose tubing fitting between an isolation valve and flow element FE 4220-H1, which resulted in chemical spray from the weep hole. The operator was wearing inadequate PPE (no chemical resistant gloves or face shield). The injured person was initially released to full duty by the medic but experienced eye irritation the next day and was evacuated. An onshore physician diagnosed chemical conjunctivitis and ordered 7 days off work, resulting in an LTA > 3 days classification.",
    "recommendations": [
      "Develop hazardous chemical awareness program",
      "Recognize possibility of leaks from weep holes in Job Safety Analysis (JSA)",
      "Require appropriate PPE for tasks involving potential chemical exposure, even when containment is not expected to be broken"
    ],
    "key_phrases": [
      "loose tubing fitting",
      "weep hole",
      "inadequate PPE",
      "chemical conjunctivitis",
      "Job Safety Analysis",
      "asphaltene inhibitor",
      "flow element"
    ]
  },
