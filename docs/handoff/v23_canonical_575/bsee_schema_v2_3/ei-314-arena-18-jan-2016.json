  "event": {
    "top_event": "Finger Injury - Crush Incident",
    "incident_type": "RW/JT (>3 days)",
    "costs": null,
    "actions_taken": [
      "Injured Floorman evacuated from rig",
      "Treatment at Terrebonne General Medical Center in Houma, Louisiana",
      "Hand specialist consultation in Metairie, Louisiana",
      "Pin insertion into left thumb on 22 January 2016",
      "Pin removal on 17 February 2016",
      "Release from hand doctor care on 16 March 2016"
    ],
    "summary": "On 18 January 2016 at approximately 21:30 hours, a Floorman sustained a crush injury to his left thumb while assisting with laying down a pump in joint assembly using an air hoist on the H&P 105 platform rig. The pump shifted during the operation, trapping the Floorman's left thumb between the pump and a fixed reverse out line valve. The injury resulted in a fracture and laceration requiring evacuation and medical treatment. The probable cause was improper hand placement, with contributing factors including congested work area with multiple crush points and incorrectly routed air hoist cable creating stored energy.",
    "recommendations": [
      "BSEE Lafayette District made no recommendations to the Office of Incident Investigation"
    ],
