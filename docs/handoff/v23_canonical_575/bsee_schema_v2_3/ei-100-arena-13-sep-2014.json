  "event": {
    "top_event": "Unintended activation of sandblasting nozzle causing personnel injury",
    "incident_type": "Slip/Trip/Fall - Personnel Injury",
    "costs": null,
    "actions_taken": [
      "Sandblaster transported to Lafayette General for evaluation",
      "BSEE Lafayette District conducted onsite investigation on September 15, 2014",
      "Lessee and Sandblasting Company decided to make shut-off valve mandatory between nozzle and air hoses"
    ],
    "summary": "On September 13, 2014 at approximately 0900 hours, a Sandblaster was injured when his blasting nozzle was accidentally activated while he was preparing to continue blasting operations. The nozzle was placed across piping while the worker attempted to put on his blasting hood. Contact with the piping is believed to have activated the nozzle, causing the blasting hose to whip through the air and spray the worker across his face, resulting in small cuts and debris entering his eyes.",
    "recommendations": [
      "Installation of mandatory shut-off valve between nozzle and air hoses, to be opened during sandblasting operations and closed when not in use"
    ],
    "key_phrases": [
      "nozzle accidentally activated",
      "contact with piping",
      "blasting hose whipped",
      "facial cuts and eye debris",
      "shut-off valve implementation"
    ]
  },
