  "event": {
    "top_event": "Arc Flash Fire",
    "incident_type": "Fire",
    "costs": "65000",
    "actions_taken": [
      "General alarm activated requiring all personnel to muster",
      "Senior Mechanic and Mechanic proceeded to Engine Control Room to assess situation",
      "Mechanics located and used handheld fire extinguisher to extinguish fire",
      "Fire Teams arrived and inspected area",
      "Fan air horn placed in doorway to pull smoke out",
      "Area barricaded and secured for BSEE investigation"
    ],
    "summary": "On 22-November-2019 at Garden Banks 491, during tripping in operations with an 11-7/8\" Easy Drill Subsurface Valve, a loss of power to drilling equipment occurred. Personnel received an alarm indicating smoke or fire in the Port Switch Gear Room. Investigation revealed that condensation accumulated on top of the Drilling Drive DC Bar cabinet from the Air Handling Unit ducting vent and ran inside the cabinet, causing an Arc Flash fire. The fire was extinguished by mechanics using a handheld fire extinguisher. Damage to the Drilling Drive DC Bar Cabinet, AHU ductwork, vent, and insulation totaled $65,000.",
    "recommendations": [
      "Remind lessees about hazards of storing combustible materials near electrical transformers or batteries",
      "Prevent possibility of condensation in Switch Gear or ECR Rooms",
      "Clean all areas with electrical cabinets frequently to prevent accumulation of dust or debris",
      "Learn from past experiences to avoid duplicating same outcome"
    ],
    "key_phrases": [
      "condensation accumulated",
      "Arc Flash",
      "Drilling Drive DC Bar cabinet",
      "Air Handling Unit ducting vent",
      "Port Switch Gear Room",
      "loss of power",
      "smoke and fire panel alarm"
    ]
  },
