  "event": {
    "top_event": "Crane boom failure and free fall",
    "incident_type": "Equipment Failure",
    "costs": "231000",
    "actions_taken": [
      "Talos shut down operations on the rig",
      "Talos notified BSEE New Orleans District after-hours phone",
      "East crane operator hoisted crane up, placed it in park position and stopped crane operations",
      "Tool pusher notified rig manager",
      "Sparrows Field Services secured boom with 10-ton chain falls and 1 inch cable slings",
      "Sparrows conducted survey of crane hydraulic system",
      "Crew reassigned from west side life capsule to east side platform life capsule"
    ],
    "summary": "On December 1, 2021, at approximately 19:30 hours, the west crane boom on the H&P 100 rig at Viosca Knoll 989 A experienced a catastrophic failure and free fell. The boom damaged a 45-person life capsule and platform handrails. No personnel were in the crane cab at the time. Investigation revealed that the ratchet and pawl locking assembly was not properly adjusted after boom winch replacement on October 14, 2021, causing failure of the load-holding mechanism. Contributing factors included motor overheating, sprag clutch slipping, and inadequate hydraulic system pressure.",
    "recommendations": [],
    "key_phrases": [
      "ratchet and pawl locking system failure",
      "improper adjustment after winch installation",
      "sprag clutch slipping",
      "hydraulic parking brake failure",
      "boom free fall",
      "life capsule damage"
    ]
  },
