  "event": {
    "top_event": "Crane Boom Collapse",
    "incident_type": "Equipment Failure",
    "costs": "730000",
    "actions_taken": [
      "Onsite investigation conducted by BSEE on May 15, 2023",
      "Failed boom cable samples sent to Core Lifting for analysis on July 20, 2023",
      "Break tests conducted on 12-foot sections of failed cable",
      "Bridle assembly inspected by Sparrows",
      "Revised crane policies and procedures implemented",
      "Wire rope replacement criteria updated to align with API RP 2D",
      "Additional wire rope micrometer evaluations added to inspection schedules",
      "Boom cable replacement scheduled at maximum 100 hours or within one year"
    ],
    "summary": "On May 12, 2023, at approximately 1605 hours, a crane boom collapse occurred on the Talos ERT LLC OCS-G02280 South Marsh Island 130 B Facility. While attempting to lower an 11,000 lb grating rack to the top deck, the boom cable broke causing the boom and load to collapse onto the deck. The boom cable failed due to fatigue from numerous cycles through the bridle sheaves, exacerbated by frequent operation at 60-to-75-degree boom angles and inadequate lubrication penetration. Total damage was $730,000 ($330,000 to deck and production equipment, $370,000 to crane). No injuries occurred.",
    "recommendations": [
      "Replace wire rope when nominal size is reached, not reduction size, per API RP 2D",
      "Include additional wire rope micrometer evaluations during quarterly and annual inspections, focusing on high rotation and wear areas",
      "Conduct boom cable replacement at maximum 100 hours or within one year on SMI-130B crane",
      "Identify alternative lubrication that provides adequate penetration to cable core"
    ],
    "key_phrases": [
      "boom cable fatigue",
      "confined area wear",
      "inadequate lubrication penetration",
      "preventative maintenance failure",
      "wire rope degradation",
      "bridle sheave cycling"
    ]
  },
