  "event": {
    "top_event": "Struck-by incident during casing bundle lowering",
    "incident_type": "Slip/Trip/Fall - Struck-by",
    "costs": null,
    "actions_taken": [
      "Injured person transported by Acadian Air Ambulance to Lafayette General Hospital",
      "Injured person released same day with no injuries"
    ],
    "summary": "On August 4, 2015, at platform HI 160JA, a bundle of 5 joints of 7 5/8 inch casing was being lowered by liftboat crane. The injured person released the tag line and moved to the starboard side to settle the swaying load. When the bundle was lowered onto 2X4 boards, the bundles shifted and a joint of casing rolled onto the injured person's left foot/ankle, causing bruising and discoloration.",
    "recommendations": [
      "Continue to reiterate the importance of utilizing tag lines and/or push poles when working with suspended loads"
    ],
    "key_phrases": [
      "tag line release",
      "inadequate cribbing",
      "failure to secure load",
      "Stop Work Authority not utilized",
      "non-adherence to rules/standards",
      "personnel positioning"
    ]
  },
