  "event": {
    "top_event": "Fire in diesel generator exhaust system",
    "incident_type": "Fire",
    "costs": null,
    "actions_taken": [
      "Operators boarded helicopter to investigate fire at EI 259A",
      "Fuel supply to generator was shut off",
      "Fire was extinguished using 300 lbs. wheel unit",
      "Generator was loaded on motor vessel and sent to Broussard La for dismantling and investigation",
      "Created Mapcon auditor and trainer position to review preventive maintenance reports"
    ],
    "summary": "On October 21, 2020 at 0647 hours, Cox Operating operators at EI 259C observed a fire at unmanned platform EI 259A. The fire originated from the diesel generator exhaust. Investigation revealed that a governor actuator linkage failure caused engine overspeed, leading to turbo lockup and oil seal leakage. The air shut off valve failed to fully close due to oil gumming up an o-ring seal, allowing the engine to continue running and increasing exhaust temperature. Carbon buildup in the exhaust was ignited by high temperatures. A preventive maintenance inspection in January 2020 had noted suspected exhaust leak but it was not properly documented in the maintenance system.",
    "recommendations": [
      "Implement Mapcon auditor and trainer position to review all preventive maintenance reports for full completion",
      "Ensure proper documentation of deficiencies discovered during preventive maintenance inspections"
    ],
    "key_phrases": [
      "governor actuator linkage failure",
      "engine overspeed event",
      "air shut off valve failure",
      "oil seal leakage",
      "exhaust leak",
      "carbon buildup",
      "preventive maintenance documentation",
      "Mapcon system"
    ]
  },
