  "event": {
    "top_event": "Finger laceration during drill collar tripping operation",
    "incident_type": "Slip/Trip/Fall - Hand Injury",
    "costs": null,
    "actions_taken": [
      "Injured person given first aid",
      "Injured person transported to Acadiana Center for Orthopedic and Occupational Medicine",
      "Injured person received sutures and full medical release"
    ],
    "summary": "On 17-June-2014 at 2230 hours, an employee with Timco (contractor) sustained a laceration to his left index finger while assisting with drill collar tripping operations on the Nabors Super Sundowner XIX drilling rig at EC-321A platform. The injured person, who was on the rig floor to adjust power tong dies, placed his hand on a lifting sub attempting to tighten it. The drill collar rotated in the mouse hole, pinching the employee's finger between the lifting sub and elevators. The employee was able to pull his finger free and received medical treatment.",
    "recommendations": [
      "Lake Charles district has no recommendations"
    ],
