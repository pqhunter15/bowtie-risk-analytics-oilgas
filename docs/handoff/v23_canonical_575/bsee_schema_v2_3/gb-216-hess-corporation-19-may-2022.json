  "event": {
    "top_event": "Hand laceration and fluid injection injury",
    "incident_type": "Injury - Laceration and injection",
    "costs": "3800",
    "actions_taken": [
      "Immediate suspension of BOP No.2 soak testing operations",
      "Safety stand down held with all personnel",
      "Injured party treated by Rig Medic",
      "Medevac helicopter evacuation on 20 May 2022",
      "Onshore surgical treatment to remove debris and injected BOP fluid",
      "Installation of protective cover sleeves over green polyflex hoses",
      "Re-routing of BOP lines as corrective action",
      "Hose sent to manufacturer for failure analysis evaluation"
    ],
    "summary": "On 19 May 2022 at 2145 hours, a SUBC USA, LLC technician sustained a left-hand laceration and injection injury when moving a 0.5-inch false hotline hose pressurized to 5000 psi during BOP soak testing on the Transocean Discoverer Inspiration drillship. The hose ruptured when the injured party placed his left hand on it to move it in order to access a leaking BOP No.2 Yellow Pod hot stab line. The injured party was evacuated by medevac helicopter and required surgery to remove debris and injected BOP fluid from his left hand.",
    "recommendations": [
      "BSEE Lafayette District made no formal recommendations to the Office of Incident Investigations"
    ],
