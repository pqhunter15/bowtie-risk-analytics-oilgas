  "event": {
    "top_event": "Employee struck by chain hoist handle during riser skate repositioning",
    "incident_type": "Struck-by injury from defective lifting equipment",
    "costs": null,
    "actions_taken": [
      "Employee sent to shore for evaluation",
      "Employee returned next day with cast and placed on restricted work duty",
      "BSEE onsite visit performed on July 29, 2016",
      "Operator investigation conducted by Maersk and Exxon"
    ],
    "summary": "On July 27, 2016, during riser running operations on the Maersk Viking, a riser skate trolley derailed from its track. While attempting to reposition the skate using a 3.2 ton Vital Lever Hoist, the chain hoist malfunctioned when tension was applied. The hoist handle spun and struck an employee on the wrist, causing a bone fracture. The root cause was a defective chain hoist missing a vital retaining pawl latch. Contributing factors included poor job planning, improper pre-use inspection, and inadequate training.",
    "recommendations": [
      "Treat all non-standard lifting and rigging (NSRs) devices as level one permitted activity",
      "Implement new process checklist for all chain and lever hoist usage",
      "Evaluate alternative lifting methods before work starts with NSRs",
      "Standardize chain and leveling hoists to single source manufacturer",
      "Standardize training and knowledge base for rig crew on lifting equipment"
    ],
    "key_phrases": [
      "riser skate trolley derailed",
      "chain hoist malfunctioned",
      "missing pawl latch",
      "struck by hoist handle",
      "bone fracture",
      "defective equipment",
      "poor job planning",
      "improper pre-use inspection",
      "inadequate training"
    ]
  },
