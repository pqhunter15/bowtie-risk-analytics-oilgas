  "event": {
    "top_event": "Hand laceration from pinching between grating and scrap basket",
    "incident_type": "Slip/Trip/Fall - Hand Injury",
    "costs": null,
    "actions_taken": [
      "Welder reported to Rig Medic for treatment",
      "Welder evacuated and transported to SouthStar Urgent Care in New Iberia, Louisiana",
      "Arena contacted BSEE Lafayette District on 20 July 2019",
      "Report submitted in eWell at 17:26 hours on 20 July 2019"
    ],
    "summary": "On 20 July 2019 at approximately 08:30 hours, a contract welder employed by Smart Fabricators of Texas, LLC sustained a three centimeter laceration to his right hand palm while placing a 2 foot by 2 foot section of metal grating into a scrap iron basket aboard the WFD 250 jack-up rig. The welder's left hand glove became snagged on the upper portion of the grating, causing his right hand to be pulled down and pinched between the lower portion of the grating and the uppermost rail of the scrap iron basket. The welder received two sutures at SouthStar Urgent Care and was released to full duty later that day.",
    "recommendations": [],
