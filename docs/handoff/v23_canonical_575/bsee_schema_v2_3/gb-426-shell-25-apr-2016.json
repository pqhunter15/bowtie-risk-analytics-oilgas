  "event": {
    "top_event": "Ejection of threaded stem striking worker",
    "incident_type": "Equipment failure resulting in worker injury",
    "costs": "207",
    "actions_taken": [
      "Injured party evaluated by rig medic",
      "Injured party evacuated to onshore medical facility",
      "Fractured stem submitted to Howard & Associates International for metallurgical evaluation",
      "H&P Root Cause Investigation Report completed"
    ],
    "summary": "On 25 April 2016 at 15:20 hours, an H&P employee was injured while removing a seat from a mud pump cylinder on the H&P 406 rig on Shell's Auger TLP. The crew was using a heavy duty seat puller with a replacement 2-inch threaded stem (not OEM certified) to pull mud pump seats that had been modified with relief grooves. When pressurized to 4500 psi, the non-OEM threaded stem failed and ejected, striking the worker's right hand and causing a fracture. Metallurgical analysis confirmed the stem failed due to overload beyond its design capacity.",
    "recommendations": [
      "BSEE Lafayette District recommends a Safety and Environmental Management Systems (SEMS) audit be conducted at the Shell Auger TLP rig"
    ],
    "key_phrases": [
      "non-OEM certified part",
      "stored energy hazard",
      "threaded stem failure",
      "overload beyond design capacity",
      "relief grooves",
      "heavy duty seat puller",
      "mud pump maintenance"
    ]
  },
