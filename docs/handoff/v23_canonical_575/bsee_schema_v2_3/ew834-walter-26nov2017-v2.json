  "event": {
    "top_event": "Hose ejection striking worker",
    "incident_type": "Injury from pressurized fluid discharge",
    "costs": null,
    "actions_taken": [
      "Immediate cessation of job to assist injured person",
      "On-board medic evaluation",
      "Helicopter evacuation to medical center in Houma, Louisiana",
      "Injured person placed on restrictive duty",
      "Installation of bolt-in cover with hose connection on tank"
    ],
    "summary": "On 26-NOV-2017 at 0405 hours, during flowback operations on the Ewing Banks 834-A platform, a roustabout (R2) was struck in the right upper collarbone by a pressurized hose that ejected from an Auxiliary Mud Tank. The incident occurred when Roustabout 1 failed to communicate that pressurized air from a rig compressor airline remained connected to a 3-inch transfer hose. When R2 lifted the hatch to verify fluid receipt, approximately 125 psi of air and fluids discharged, causing the hose to strike him. Root causes included inadequate communication between roustabouts, failure to secure the hose, failure to follow operating procedures, and insufficient supervisor delegation. The injured person was evacuated and placed on restricted duty, with full duty release scheduled for 1/15/2018.",
    "recommendations": [
      "Update JSA for transferring produced water to include potential hose restrictions, associated hazards, use of pressurized air and associated hazards, and securing the dump end of transfer hose with engineered device",
      "Develop procedures for all rigs for securing both ends of all transfer hoses when transferring fluids from one tank to another regardless of pressure status"
    ],
    "key_phrases": [
      "inadequate communication",
      "failed to secure hose",
      "pressurized air discharge",
      "hose ejection",
      "insufficient delegation",
      "failure to follow procedures",
      "hazard identification failure"
    ]
  },
