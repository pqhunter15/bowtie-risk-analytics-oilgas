      "portable bandsaw",
      "two-handed tool operated with one hand",
      "tubing not secured",
      "inadequate tool selection",
      "rushing to complete job",
      "inadequate hazard documentation",
      "cut resistant gloves worn but ineffective"
    ]
  },
