  "event": {
    "top_event": "Dropped casing joint",
    "incident_type": "Structural Damage - Crane",
    "costs": null,
    "actions_taken": [
      "Crane's gripper function removed from service",
      "Full technical investigation initiated",
      "Contractor working with original equipment manufacturer to replace automated pipe adapter system with manual pin style system"
    ],
    "summary": "On April 7, 2017, a joint of 9 7/8\" casing was dropped by the Pipe Deck Pipe Handler (PDPH) crane on the Seadrill Sevan Louisiana while being transferred between pipe bays. A leaking hydraulic seal on the aft pipe adapter cylinder caused the gripper to lose closing pressure, allowing the casing to slip during the lift. The crane operator had to periodically re-initialize the casing settings due to the hydraulic leak but did not identify this as a system malfunction. All personnel were in safe zones and no injuries or equipment damage resulted.",
    "recommendations": [
      "Replace automated pipe adapter system with manual pin style system to eliminate leaking hydraulic seals and provide visual confirmation of positive latch"
    ],
    "key_phrases": [
      "hydraulic seal leak",
      "gripper deactivation",
      "casing slippage",
      "lack of awareness",
      "re-initialization",
      "equipment failure"
    ]
  },
