  "event": {
    "top_event": "Diver hand injury during casing positioning",
    "incident_type": "Lost Time Accident (>3 days)",
    "costs": null,
    "actions_taken": [
      "Stop Work Authority issued",
      "Diver decompressed in hyperbaric chamber",
      "Diver transported to hospital via crew boat",
      "Safe Work Plan developed post-incident",
      "ROV alternative discussed",
      "Hand hold fabrication option discussed"
    ],
    "summary": "On July 20, 2018, a diver suffered significant injuries to the fingers on his right hand while attempting to maneuver a 60-inch casing over a wellhead during plug and abandon operations in Ship Shoal 114 field. The diver slipped while straddling the casing and grabbed the lip to catch himself. A sea swell caused the casing to shift unexpectedly, mashing the diver's fingers between the 36-inch and 60-inch casings. The diver suffered amputation of the right index finger and was transported to hospital for treatment.",
    "recommendations": [
      "Use Remotely Operated Vehicle (ROV) to eliminate diver presence",
      "Fabricate hand holds on casing if diver is required",
      "Reinforce hand and body placement importance in Safety Meetings and JSEA"
    ],
    "key_phrases": [
      "Poor hand and body placement",
      "Sea swell caused casing to shift",
      "Diver slipped while straddling casing",
      "Fingers mashed between casings",
      "Amputation of right index finger"
    ]
  },
