  "event": {
    "top_event": "Loss of Load Control",
    "incident_type": "Dropped Object",
    "costs": null,
    "actions_taken": [
      "Job stopped immediately",
      "Area secured",
      "Transocean and BHP management notified",
      "Proposed addition of dual-control foot pedal for CTE slips operation",
      "Review of Rack Back Console placement to relocate outside Red Zone"
    ],
    "summary": "On December 20, 2020, a 4,725-pound joint of 14-inch casing fell across the rig floor of the Transocean Deepwater Invictus drillship after the clamp type elevators (CTE) unlatched when the joint was lowered to the rig floor during troubleshooting of casing slips. The RBC panel operator prematurely functioned the CTE to 'slips up' position during troubleshooting, which allowed the elevators to open and release the casing when weight was removed. No injuries occurred, though an unauthorized Red Zone entry was made by a casing crew member who escaped unharmed.",
    "recommendations": [
      "Implement dual-control foot pedal (or equivalent) requiring both Driller and RBC panel operator input to open CTE slips",
      "Review and relocate Rack Back Console system placement to area outside Red Zone",
      "Reinforce Red Zone access control procedures and authorization requirements"
    ],
    "key_phrases": [
      "clamp type elevators unlatched",
      "RBC panel operator functioned CTE to slips up prematurely",
      "unauthorized Red Zone entry",
      "dual-control mechanism",
      "loss of weight allowed slips to open"
    ]
  },
