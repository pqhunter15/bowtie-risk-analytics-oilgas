  "event": {
    "top_event": "Hand Injury from Pressurized Tubing",
    "incident_type": "Injury - Lost Time Accident (>3 days)",
    "costs": null,
    "actions_taken": [
      "Testing immediately stopped",
      "Injured employee brought to onboard medic",
      "Employee transported to medical facility",
      "BSEE Lafayette District conducted onsite investigation on November 19, 2014"
    ],
    "summary": "On November 18, 2014 at approximately 1100 hours, an employee injured his left hand while attempting to activate suction and discharge valves on a booster pump. During valve activation, a half-inch tubing came loose on the actuator top connection and rotated, striking the employee's left hand. The tubing contained approximately 100 psi. The employee failed to properly secure the fitting before applying pressure. The employee sustained a fractured left hand and was transported to a medical facility.",
