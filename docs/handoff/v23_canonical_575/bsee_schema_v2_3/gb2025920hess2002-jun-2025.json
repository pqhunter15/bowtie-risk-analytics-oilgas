  "event": {
    "top_event": "Hand Injury - Partial Amputation",
    "incident_type": "Caught by Moving Equipment",
    "costs": null,
    "actions_taken": [
      "Transocean Second Engineer reported to Rig Medic for treatment",
      "Medevac helicopter evacuation on 3 June 2025 to East Jefferson Hospital",
      "Minor surgery performed to close wound",
      "Employee released to work with light duty restrictions",
      "BSEE onsite Incident Follow-up Investigation conducted on 4 June 2025"
    ],
    "summary": "On 02 June 2025 at 2230 hours, a Transocean Second Engineer suffered a partial amputation of the left hand middle and ring fingertips while checking the tension on an air handling unit (AHU) belt in the Mud Module Electrical Room. The engineer placed his left hand on a moving belt without proper energy isolation (LOTO), supervision, or communication of the task change. The belt drew his hand between the belt and pulley, causing the injury.",
